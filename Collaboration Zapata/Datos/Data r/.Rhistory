#### Cargamos los paquetes que ayudaran en nuestro análisis. el Primer paquete sirve para leer el bases de datos en excel.
#### el 2 paquete nos ayuda para .... el corrplot nos sirve para presentar la matriz de correlaciones. y el ggplot nos sirve para graficar las correlaciones.
.#### el paquete car sirve par modificar los nombres de las variables. pues he visto que el nombre original esta muy largo y podría presentar dificultades para graficar-
library(readxl)
library(nortest)
library(dplyr)
library(ggplot2)
library(rriskDistributions)
library(corrplot)
library(ggplot2)
library(quantreg)
library(car)
library(psych)
#### Aplicamos la prueba de Shapiro Wilk que nos ayuda a identificar normalidad en los datos
#### también podemos aplicar el lilie test (Kolmogorov, para identificar normalidad en los datos
shapiro.test(Datos_Final$Edad)
shapiro.test(Datos_Final$Género)
shapiro.test(Datos_Final$Educ)
shapiro.test(Datos_Final$ocup)
shapiro.test(Datos_Final$Late)
shapiro.test(Datos_Final$Esta)
shapiro.test(Datos_Final$Ingr)
shapiro.test(Datos_Final$Consumo)
shapiro.test(Datos_Final$IMC)
shapiro.test(Datos_Final$Trab)
shapiro.test(Datos_Final$Inter)
shapiro.test(Datos_Final$acul)
shapiro.test(Datos_Final$`SF-36`)
shapiro.test(Datos_Final$Pmemo)
shapiro.test(Datos_Final$Pleng)
shapiro.test(Datos_Final$PFE)
shapiro.test(Datos_Final$Paten)
lillie.test(Datos_Final$Edad)
boxplot(Datos_Final$Edad)
pairs(Datos_Final)
pairs.panel(Datos_Final)
pairs.panels(Datos_Final)
