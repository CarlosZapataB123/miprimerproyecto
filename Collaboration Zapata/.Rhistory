Ocupacion_D <-factor(Datos_Final$Ocup_Rec)
is.factor(Ocupacion_D)
lateralidad_D <-factor(Datos_Final$Later)
is.factor(lateralidad_D)
Estado_C_D <-factor(Datos_Final$Estado_C)
is.factor(Estado_C_D)
