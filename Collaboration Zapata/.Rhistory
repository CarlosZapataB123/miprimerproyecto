Datos_Final <- read_excel("DATABASE.xlsx")
View(Datos_Final)
summary(Datos_Final)
summary(Datos_Final$ReyC, Datos_Final$ReyM, Datos_Final$Rec_Inmediato, Datos_Final$`HLVRT-ET`, Datos_Final$Reconocimiento_correc)
