is.factor(Consumo_D)
view(Consumo_D)
modelo1ReyCtotal<- lm(Datos_Final$ReyC ~ Datos_Final$Edad + Datos_Final$Género + Datos_Final$Educ + Ocupacion_D + lateralidad_D + Estado_C_D + Datos_Final$Ingresos + Consumo_D + Datos_Final$IMC + Datos_Final$Trab + Datos_Final$Internet + Datos_Final$Aculturacion)
