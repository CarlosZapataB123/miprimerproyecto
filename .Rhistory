# ============================================================
data_clean <- data_clean %>%
dplyr::rename(
# ----- Identification -----
id               = ID,
eval_date        = `Fecha de evaluación (dd/mm/aaaa)`,
# ----- Sociodemographic -----
age              = Edad,
sex              = Género,             # 1 = Male, 2 = Female
education_yrs    = `Años de educacion`,
occupation       = `OCUPACIÓN U OFICIO`,
handedness       = LATERALIDAD,        # 1 = Right, 2 = Left, 3 = Both
bilingual        = BILINGÜE,
civil_status     = `ESTADO CIVIL ACTUAL`,  # 1=Single, 2=Partnered, 3=Separated, 4=Widowed
area_residence   = `ÁREA DE RESIDENCIA`,
monthly_income   = `INGRESOS MENSUALES`,
alcohol_use      = `CONSUMO DE ALCOHOL`, # 1=Never/rarely, 2=1-2x/week, 3=3-4x/week
bmi              = ICM,
work_outside     = `TRABAJOS POR FUERA DE LA COMUNIDAD`, # 0=No, 1=Yes
internet_access  = `SERVICIOS DE INTERNET`,              # 0=No, 1=Yes
health_service   = `SERVICIOS DE SALUD`,
electricity      = `SERVICIO DE ELECTRICIDAD`,
# ----- Acculturation scale items (16 items) -----
acul_speak       = HABLAR,
acul_read        = LEER,
acul_write       = ESCRIBIR,
acul_lang_child  = `IDIOMA INFANCIA`,
acul_lang_home   = `IDIOMA EN CASA`,
acul_lang_work   = `IDIOMA EN TRABAJO`,
acul_lang_friend = `IDIOMA AMIGOS`,
acul_lang_think  = `IDIOMA PENSAMIENTO`,
acul_friends     = `AMIGOS CERCANO`,
acul_parties     = FIESTAS,
acul_visits      = VISITAS,
acul_children    = `AMIGOS DE LOS HIJOS`,
acul_rituals     = RITUALES,
acul_religion    = `RELIGIÓN`,
acul_clothing    = VESTIMENTA,
acul_identity    = `SE CONSIDERA`,
# ----- Screening instruments -----
mmse             = MMSE,
phq9             = `PHQ-9`,
barthel          = Bartel,
# ----- Neuropsychological outcomes -----
# Learning & memory - ROCFT
rocft_copy       = `FIGURA DE REY PUNTUACIÓN COPIA`,
rocft_memory     = `FIGURA DE REY PUNTUACIÓN MEMORIA INMEDIATA`,
# Learning & memory - HVLT-R
hvlt_t1          = `HLVRT-R ENSAYO 1`,
hvlt_t2          = `HLVRT-R ENSAYO 2`,
hvlt_t3          = `HLVRT-R ENSAYO 3`,
hvlt_total       = `TOTAL RECUERDO INMEDIATO`,
hvlt_delay       = `HLVRT-R EVOCACIÓN TARDÍA`,
hvlt_recog       = ` RECONOCIMIENTO TOTAL CORRECTAS`,  # note: leading space in original
hvlt_fp_related  = `FALSOS POSITIVOS SEMANTICAMENTE RELACIONADOS`,
hvlt_fp_unrelated = `FALSOS POSITIVOS NO RELACIONADOS SEMANTICAMENTE`,
hvlt_errors      = `NÚMERO TOTAL ERRORES`,
# Verbal fluency (phonological)
vf_m             = `FLUIDEZ VERBAL M`,
vf_r             = `FLUIDEZ VERBAL R`,
vf_p             = `FLUIDEZ VERBAL P`,
# Verbal fluency (semantic)
vf_animals       = `FLUIDEZ SEMANTICA ANIMALES`,
vf_fruits        = `FLUIDEZ SEMANTICA FRUTAS`,
# Attention - Stroop
stroop_words     = `STROOP P`,
stroop_colors    = `STROOP C`,
stroop_inhibition = `STROOP PC`,
stroop_corrected = `STROOP PC'`,
stroop_interfere = INTERFERENCIA,
# Executive function - M-WCST
wcst_categories  = `M-WCST Categorías Correctas`,
wcst_persev      = `M-WCST Perseveraciones`,
wcst_errors_type = `M-WCST Errores`,
wcst_errors_total = `M-WCST total Errores`,
# Processing speed - Trail Making Test
tmt_a            = `TMT A Tiempo (sg)`,
tmt_b            = `TMT B Tiempo (sg)`,
# Attention - Brief Test of Attention
bta_num          = `BTA-N`,
bta_let          = `BTA-L`,
bta_total        = Total,
# Processing speed - SDMT
sdmt_correct     = SDMT,
sdmt_errors      = Errores
)
✅ Fase 2a — Base de datos limpia y script reproducible
# Cargo solo los paquetes que necesito para este script.
# Los organizo por tema para que sea fácil saber qué hace cada uno
# cuando vuelva a leer el código en 6 meses.
# Rutas del proyecto
library(here)
# Lectura y manipulación de datos
library(readxl)
library(dplyr)
library(tidyr)
library(purrr)
# Visualización
library(ggplot2)
library(patchwork)   # combinar varios gráficos en una sola figura
# Teoría de Respuesta al Ítem
library(mirt)        # modelos TRI politómicos — PCM, GRM, 2PL
install.packages("mirt")
# Cargo solo los paquetes que necesito para este script.
# Los organizo por tema para que sea fácil saber qué hace cada uno
# cuando vuelva a leer el código en 6 meses.
# Rutas del proyecto
library(here)
# Lectura y manipulación de datos
library(readxl)
library(dplyr)
library(tidyr)
library(purrr)
# Visualización
library(ggplot2)
library(patchwork)   # combinar varios gráficos en una sola figura
# Teoría de Respuesta al Ítem
library(mirt)        # modelos TRI politómicos — PCM, GRM, 2PL
# Verifico que todo cargó bien
cat("Paquetes cargados correctamente.\n")
cat("Versión de R:", R.version$version.string, "\n")
cat("Fecha:", as.character(Sys.Date()), "\n")
# Cargo la base maestra que ya está limpia y validada.
# Esta base tiene los 88 participantes con los ítems de aculturación
# ya corregidos — no la original, sino la que construimos juntos.
datos <- readxl::read_excel(
here::here("01_Articulo1", "data", "MASTER_DATABASE_Embera_n88.xlsx"),
na = c("", "NA", "N/A", " ")
)
# Verifico que llegaron bien las dimensiones esperadas
cat("Participantes:", nrow(datos), "\n")
cat("Variables:    ", ncol(datos), "\n")
# Defino los 16 ítems de la escala en el orden en que aparecen
# en la base. Estos son los nombres exactos de las columnas
# después de la limpieza que hicimos.
items_acul <- c(
"HABLAR", "LEER", "ESCRIBIR",
"IDIOMA INFANCIA", "IDIOMA EN CASA", "IDIOMA EN TRABAJO",
"IDIOMA AMIGOS", "IDIOMA PENSAMIENTO",
"AMIGOS CERCANO", "FIESTAS", "VISITAS", "AMIGOS DE LOS HIJOS",
"RITUALES", "RELIGIÓN", "VESTIMENTA", "SE CONSIDERA"
)
# Extraigo solo los ítems en un data.frame limpio
df_acul <- datos %>%
dplyr::select(ID, dplyr::all_of(items_acul))
# Verifico
cat("Dimensiones del data.frame de ítems:", nrow(df_acul), "x", ncol(df_acul), "\n")
cat("Casos completos (sin ningún NA):", sum(complete.cases(df_acul)), "\n")
cat("\nPrimeras filas:\n")
print(head(df_acul, 5))
# Calculo la frecuencia de cada categoría por ítem.
# Quiero detectar categorías con menos de 5 respuestas porque
# eso hace que los parámetros TRI sean inestables — el modelo
# no tiene suficiente información para estimar bien ese umbral.
freq_items <- purrr::map_dfr(items_acul, function(item) {
col  <- df_acul[[item]]
cats <- sort(unique(na.omit(col)))
purrr::map_dfr(cats, function(k) {
tibble::tibble(
item      = item,
categoria = k,
n         = sum(col == k, na.rm = TRUE)
)
})
})
# Gráfico de barras por ítem
ggplot2::ggplot(freq_items,
ggplot2::aes(x = factor(categoria), y = n)) +
ggplot2::geom_col(fill = "#2E86AB", color = "white") +
ggplot2::geom_text(ggplot2::aes(label = n),
vjust = -0.4, size = 2.8) +
ggplot2::geom_hline(yintercept = 5,
linetype = "dashed",
color = "red",
alpha = 0.7) +
ggplot2::facet_wrap(~ item, ncol = 4, scales = "free_y") +
ggplot2::labs(
title    = "Distribución de respuestas por ítem",
subtitle = "Línea roja = n mínimo recomendado por categoría (n = 5)",
x = "Categoría de respuesta",
y = "Frecuencia"
) +
ggplot2::theme_minimal(base_size = 10) +
ggplot2::theme(
strip.text = ggplot2::element_text(size = 7.5, face = "bold")
)
# Genero una tabla resumen que muestra, para cada ítem:
# - cuántas categorías tiene
# - cuál es la frecuencia mínima observada
# - en qué categoría ocurre ese mínimo
# - si necesita colapso (frecuencia mínima < 5)
tabla_diag <- purrr::map_dfr(items_acul, function(item) {
col   <- df_acul[[item]]
freqs <- table(col)
tibble::tibble(
Item          = item,
Categorias    = paste(names(freqs), collapse = " | "),
Frecuencias   = paste(as.numeric(freqs), collapse = " | "),
N_categorias  = length(freqs),
Frec_minima   = min(freqs),
Cat_problemas = names(freqs)[which(freqs < 5)],
Colapsar      = ifelse(min(freqs) < 5, "Sí", "No")
)
})
knitr::kable(
tabla_diag,
caption = "Diagnóstico de categorías por ítem — escala de aculturación",
col.names = c("Ítem", "Categorías", "Frecuencias",
"N categ.", "Frec. mín.", "Categ. < 5", "¿Colapsar?")
)
print(tabla_diag)
# Este bloque configura el comportamiento global del documento.
# include=FALSE significa que este chunk no aparece en el HTML —
# es infraestructura, no análisis.
knitr::opts_chunk$set(
echo    = TRUE,    # muestra el código en el HTML
message = FALSE,   # suprime mensajes de los paquetes
warning = FALSE,   # suprime advertencias
fig.align = "center",
fig.width  = 9,
fig.height = 6,
dpi = 300
)
# Fijo la semilla antes de cualquier análisis.
# Cualquier proceso aleatorio (bootstrap, remuestreo, UMAP)
# dará el mismo resultado cada vez que corras el script.
set.seed(2024)
# Cargo solo los paquetes que necesito para este script.
# Los organizo por tema para que sea fácil saber qué hace cada uno
# cuando vuelva a leer el código en 6 meses.
