# FUENTE MAESTRA: MASTER_DATABASE_Embera_n88.xlsx
# Ubicación: 01_Articulo1/data/
# Contenido: n=88 participantes válidos, 147 variables
# ============================================================
raw_data <- readxl::read_excel(
path = here::here("01_Articulo1", "data", "MASTER_DATABASE_Embera_n88.xlsx"),
na   = c("", "NA", "N/A", " ")
)
cat("Dimensiones:", nrow(raw_data), "filas x", ncol(raw_data), "columnas\n")
cat("Esperado: 88 x 147\n")
excluded_ids <- c("AG85S2031", "CZ63S1061", "CZ64S2048", "CZ87S1082")
n_excl <- sum(raw_data$ID %in% excluded_ids)
if (nrow(raw_data) == 88 & ncol(raw_data) == 147 & n_excl == 0) {
cat("\u2705 Base maestra cargada correctamente\n")
} else {
cat("\u26a0\ufe0f  Revisar: dimensiones no coinciden\n")
}
dplyr::glimpse(raw_data)
